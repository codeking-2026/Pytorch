    <Content Include="run_torchvision.bat" />
  </ItemGroup>
  <ItemGroup>
    <Folder Include="src\" />
    <Folder Include="data\" />
    <Folder Include="data\images\train\" />
    <Folder Include="data\images\val\" />
    <Folder Include="data\labels\train\" />
    <Folder Include="data\labels\val\" />
  </ItemGroup>
  <Import Project="$(MSBuildExtensionsPath32)\Microsoft\VisualStudio\v$(VisualStudioVersion)\Python Tools\Microsoft.PythonTools.targets" />
</Project>
